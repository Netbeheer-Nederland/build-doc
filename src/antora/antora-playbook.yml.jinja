site:
  title: NBNL Modellen — {{ site_title }}
  url: {{ site_url }}
  start_page: ROOT::index.adoc
content:
  sources:
    - url: ''
      tags: '@({1..9})*({0..9}).+({0..9})'
      branches:
        - main
        - draft*
      start_path: src
asciidoc:
  attributes:
    page-pagination: ''
    experimental: ''
    kroki-fetch-diagram: true  # Whether rendering is done server-sided so the images are served statically.
    kroki-default-format: svg@
    kroki-server-url: http://fruit.ritger.nl:9000
  extensions:
    - asciidoctor-kroki
output:
  clean: true
  dir: output/docs/html
ui:
  bundle:
    url: https://gitlab.com/antora/antora-ui-default/-/jobs/artifacts/HEAD/raw/build/ui-bundle.zip?job=bundle-stable
    snapshot: true
  supplemental_files: /opt/build/antora/supplemental-ui/{% if has_nav == "false" %}single-page{% else %}default{% endif %}
antora:
  extensions:
    - require: '@antora/lunr-extension'
